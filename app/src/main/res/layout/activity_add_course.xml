<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical"
    android:padding="24dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#1E293B" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Add New Course"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#0F172A"/>
    </RelativeLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="86dp"
        android:layout_height="86dp"
        android:layout_gravity="center"
        android:layout_marginBottom="44dp"
        app:cardCornerRadius="43dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#EFF6FF">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="22dp"
            android:src="@drawable/ic_notes"
            app:tint="#3B82F6"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Course Name"
        android:textColor="#334155"
        android:fontFamily="sans-serif-bold"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>
    <EditText
        android:id="@+id/etCourseName"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_input_field"
        android:hint="e.g. Advanced Mathematics"
        android:paddingHorizontal="20dp"
        android:textColor="#1E293B"
        android:textColorHint="#94A3B8"
        android:inputType="textCapWords"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Credit Hours"
        android:textColor="#334155"
        android:fontFamily="sans-serif-bold"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>
    <Spinner
        android:id="@+id/spinnerCredits"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_spinner_custom"
        android:paddingStart="20dp"
        android:paddingEnd="40dp"
        android:overlapAnchor="false"
        android:spinnerMode="dropdown"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expected Grade"
        android:textColor="#334155"
        android:fontFamily="sans-serif-bold"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>
    <Spinner
        android:id="@+id/spinnerGrade"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_spinner_custom"
        android:paddingStart="20dp"
        android:paddingEnd="40dp"
        android:overlapAnchor="false"
        android:spinnerMode="dropdown"
        android:layout_marginBottom="44dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveCourse"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Save Course"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:backgroundTint="#3B82F6"
        android:fontFamily="sans-serif-black"
        app:cornerRadius="18dp"
        android:layout_marginBottom="14dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="#1E293B"
        android:fontFamily="sans-serif-black"
        app:cornerRadius="18dp"
        android:backgroundTint="#E2E8F0"/>

</LinearLayout>