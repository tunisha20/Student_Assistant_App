<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:background="@drawable/nav_header_premium_bg"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="28dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="82dp"
        android:layout_height="82dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="2dp"
        app:strokeColor="@color/ice_blue_glow">

        <ImageView
            android:id="@+id/nav_header_profile_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp"
            android:src="@drawable/ic_user"
            app:tint="@color/premium_blue_light" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/nav_header_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:textColor="@color/text_slate_dark"
        android:textSize="24sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="-0.02" />

    <TextView
        android:id="@+id/nav_header_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_slate_muted"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium" />
</LinearLayout>