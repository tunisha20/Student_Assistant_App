<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoutineContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="75dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvCardStartTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:00"
                android:textColor="#1E293B"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"/>
            <View
                android:layout_width="2dp"
                android:layout_height="15dp"
                android:layout_marginVertical="2dp"
                android:background="#E2E8F0"/>
            <TextView
                android:id="@+id/tvCardEndTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:30"
                android:textColor="#94A3B8"
                android:textSize="12sp"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="12dp"
            android:background="#F1F5F9"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvCardSubject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subject Name"
                android:textColor="#6366F1"
                android:textSize="17sp"
                android:fontFamily="sans-serif-black"/>
            <TextView
                android:id="@+id/tvCardRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room: 402 • Theory"
                android:textColor="#64748B"
                android:layout_marginTop="2dp"
                android:textSize="12sp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelClass"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#EF4444"
            android:textSize="10sp"
            android:padding="0dp"
            app:icon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconTint="#EF4444"
            app:iconSize="14dp"
            app:layout_constraintEnd_toEndOf="parent"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>