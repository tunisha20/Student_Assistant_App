<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FF"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#1A1C1E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="Add New Task"
            android:textColor="#1A1C1E"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task Title"
        android:textColor="#44474E"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etTaskTitle"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_field"
        android:hint="e.g. Finish Physics Assignment"
        android:paddingHorizontal="16dp"
        android:textColor="#1A1C1E"
        android:textColorHint="#9E9E9E" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Category"
        android:textColor="#44474E"
        android:textSize="14sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnAcademic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Academic"
                android:background="@drawable/bg_chip_selected"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/btnPersonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personal"
                android:background="@drawable/bg_chip_unselected"
                android:textColor="#44474E"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/btnWork"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Work"
                android:background="@drawable/bg_chip_unselected"
                android:textColor="#44474E"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/btnProject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Project"
                android:background="@drawable/bg_chip_unselected"
                android:textColor="#44474E"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Due Date"
        android:textColor="#44474E"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDueDate"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:text="mm/dd/yyyy"
        android:textColor="#1A1C1E"
        android:drawableEnd="@android:drawable/ic_menu_my_calendar" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Priority"
        android:textColor="#44474E"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnLow"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Low"
            android:gravity="center"
            android:background="@drawable/bg_priority_left"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/btnMed"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Med"
            android:gravity="center"
            android:textColor="#2962FF"
            android:background="@drawable/bg_priority_selected"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/btnHigh"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="High"
            android:gravity="center"
            android:background="@drawable/bg_priority_right"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Description"
        android:textColor="#44474E"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etNoteDetails"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_field"
        android:gravity="top"
        android:hint="Add some notes about this task..."
        android:padding="16dp"
        android:textColor="#1A1C1E"
        android:textColorHint="#9E9E9E" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnSaveTask"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Save Task"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#2962FF"
        app:cornerRadius="12dp" />

</LinearLayout>